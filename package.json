{
  "name": "@verevoir/editor",
  "version": "0.3.6-beta.1",
  "license": "MIT",
  "description": "Lightweight React content editing components driven by Verevoir schema definitions",
  "homepage": "https://verevoir.io",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "dist/styles",
    "llms.txt"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/editor.git"
  },
  "funding": "https://buymeacoffee.com/verevoir",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@verevoir/schema": "^0.3.1-beta.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  }
}
